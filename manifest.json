{
  "manifest_version": 3,
  "name": "Instant Sidebar Translator",
  "version": "1.0",
  "description": "Translates selected text instantly in a side panel.",
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "permissions": ["sidePanel"],
  "host_permissions": ["https://translate.googleapis.com/*"],
  "action": {
    "default_title": "Click to open translator sidebar",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "sidebar.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "all_frames": true,
      "match_about_blank": true,
      "match_origin_as_fallback": true
    }
  ]
}